APP_MODE=observe
APP_ENV=dev
LOG_LEVEL=info
LOG_FORMAT=json
HTTP_ADDR=:8080
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_SECRET=replace-me
TELEGRAM_WEBHOOK_URL=
TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgres://tg_spam:replace-me@postgres:5432/tg_spam?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_REQUIREPASS=
REDIS_DB=0
CONTENT_HASH_KEY=replace-with-at-least-32-characters
RULES_DIR=/app/configs/rules
AI_DETECTION_ENABLED=false
AI_DETECTION_MODE=observe
AI_DETECTION_PROVIDER=openai_compatible
AI_DETECTION_OPENAI_COMPATIBLE_ENDPOINT=
AI_DETECTION_OPENAI_COMPATIBLE_MODEL=
AI_DETECTION_OPENAI_COMPATIBLE_API_KEY=
AI_DETECTION_BEDROCK_REGION=
AI_DETECTION_BEDROCK_MODEL_ID=
AI_DETECTION_BEDROCK_AUTH_MODE=iam_role
AI_DETECTION_BEDROCK_ACCESS_KEY_ID=
AI_DETECTION_BEDROCK_SECRET_ACCESS_KEY=
AI_DETECTION_BEDROCK_SESSION_TOKEN=
SEMANTIC_MEMORY_ENABLED=false
SEMANTIC_MEMORY_EMBEDDING_PROVIDER=openai_compatible
SEMANTIC_MEMORY_EMBEDDING_VERSION=v1
SEMANTIC_MEMORY_EMBEDDING_DIMENSIONS=0
SEMANTIC_MEMORY_SIMILARITY_THRESHOLD=0.88
SEMANTIC_MEMORY_SPAM_SIMILARITY_THRESHOLD=0.90
SEMANTIC_MEMORY_HAM_SIMILARITY_THRESHOLD=0.95
SEMANTIC_MEMORY_MAX_NEIGHBORS=5
SEMANTIC_MEMORY_CACHE_TTL=168h
SEMANTIC_MEMORY_OPENAI_COMPATIBLE_ENDPOINT=
SEMANTIC_MEMORY_OPENAI_COMPATIBLE_MODEL=
SEMANTIC_MEMORY_OPENAI_COMPATIBLE_API_KEY=
SEMANTIC_MEMORY_BEDROCK_REGION=
SEMANTIC_MEMORY_BEDROCK_MODEL_ID=
SEMANTIC_MEMORY_BEDROCK_AUTH_MODE=iam_role
SEMANTIC_MEMORY_BEDROCK_ACCESS_KEY_ID=
SEMANTIC_MEMORY_BEDROCK_SECRET_ACCESS_KEY=
SEMANTIC_MEMORY_BEDROCK_SESSION_TOKEN=
