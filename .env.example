APP_MODE=observe
APP_ENV=dev
LOG_LEVEL=info
LOG_FORMAT=json
HTTP_ADDR=:8080
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_SECRET=replace-me
TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890
POSTGRES_PASSWORD=replace-me
DATABASE_URL=postgres://tg_spam:replace-me@postgres:5432/tg_spam?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_REQUIREPASS=
REDIS_DB=0
CONTENT_HASH_KEY=replace-with-at-least-32-characters
RULES_DIR=/app/configs/rules
